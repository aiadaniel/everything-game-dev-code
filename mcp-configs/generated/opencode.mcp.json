{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "blender": {
      "type": "local",
      "command": [
        "uvx",
        "blender-mcp"
      ],
      "enabled": true
    },
    "fal-media": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "fal-ai-mcp-server"
      ],
      "enabled": true,
      "environment": {
        "FAL_KEY": "${FAL_KEY}"
      }
    },
    "godot-editor": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@coding-solo/godot-mcp"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "unity-editor": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpforunityserver",
        "mcp-for-unity",
        "--transport",
        "stdio"
      ],
      "enabled": true
    }
  }
}
