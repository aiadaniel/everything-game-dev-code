# Example environment values for local scaffold tooling.
# These are the only variables the scripts and hooks actually read.
# Set them in your shell or harness environment — no .env loader is used.

# Active engine profile consumed by hooks and profile resolution.
# Valid values: unity | unreal | godot | web
# (Alternative: run `node scripts/setup-profile.js <engine>` to persist it
# in .game-dev/profile.json instead.)
GAME_DEV_PROFILE=

# Workspace root for .game-dev/ state files. Defaults to the current
# working directory when unset.
WORKSPACE_ROOT=

# OPTIONAL: API key for the default generative asset provider (fal.ai), read by
# `node scripts/generate-assets.js` via manifests/asset-providers.json.
# Leave unset to keep using the scaffold's placeholder/procedural asset tooling
# (the default). Set it only to enable the optional /generate-assets capability.
# Get one at https://fal.ai — never commit real keys (.env files are gitignored).
FAL_KEY=

# Install profiles (e.g. unity-production, godot-indie-2d) are not set via
# environment — see manifests/install-profiles.json and
# `node scripts/install-profile.js --profile <id>`.
